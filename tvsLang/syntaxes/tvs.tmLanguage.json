{
  "scopeName": "source.tvs",
  "name": "TVS (Televisions)",
  "patterns": [
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#modules" },
    { "include": "#strings" },
    { "include": "#comments" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "keywords": {
      "patterns": [{
        "name": "keyword.control.tvs",
        "match": "\\b(tv|glitch|global|if|else|elseif|while|for|in|return|try|catch|import|break|continue|null|true|false|and|or|not)\\b"
      }]
    },
    "builtins": {
      "patterns": [{
        "name": "support.function.builtin.tvs",
        "match": "\\b(print|ask|len|split|join|read|write|append|sin|cos|sqrt|rand|abs|range|convert|wait|delay)\\b"
      }]
    },
    "modules": {
      "patterns": [
        {
          "name": "support.class.tvs",
          "match": "\\b(random|antenna|string)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.tvs",
        "match": "(==|!=|<=|>=|=|\\+|\\-|\\*|/|<|>|\\[|\\]|\\{|\\}|\\(|\\)|;|:|,|\\.)"
      }]
    },
    "strings": {
      "name": "string.quoted.double.tvs",
      "begin": "\"",
      "end": "\""
    },
    "comments": {
      "name": "comment.line.double-slash.tvs",
      "begin": "//",
      "end": "$"
    },
    "numbers": {
      "name": "constant.numeric.tvs",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  }
}